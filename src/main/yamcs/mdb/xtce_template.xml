<?xml version="1.0" encoding="UTF-8"?>
<SpaceSystem name="myproject" xmlns="http://www.omg.org/spec/XTCE/20180204" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.omg.org/spec/XTCE/20180204 https://www.omg.org/spec/XTCE/20180204/SpaceSystem.xsd">
    <TelemetryMetaData>
        <ParameterTypeSet>
			<!-- CUC Time Encoding -->
			<AbsoluteTimeParameterType name="CUC_Time">
                <Encoding>
                    <CUCTimeEncoding>
                        <epoch>2025-01-01T00:00:00Z</epoch>
                        <implicitPField />
                        <cucSegments>
                            <Segment sizeInBits="32" />
                            <Segment sizeInBits="32" />
                        </cucSegments>
                    </CUCTimeEncoding>
                </Encoding>
            </AbsoluteTimeParameterType>
            <!-- CCSDS Header Types -->
            <IntegerParameterType name="CCSDS_Version_Type" signed="false">
                <UnitSet />
                <IntegerDataEncoding sizeInBits="3" />
            </IntegerParameterType>
            <BooleanParameterType name="CCSDS_Type_Type">
                <UnitSet />
                <IntegerDataEncoding sizeInBits="1" />
            </BooleanParameterType>
            <BooleanParameterType name="CCSDS_Sec_Hdr_Flag_Type">
                <UnitSet />
                <IntegerDataEncoding sizeInBits="1" />
            </BooleanParameterType>
            <IntegerParameterType name="CCSDS_APID_Type" signed="false">
                <UnitSet />
                <IntegerDataEncoding sizeInBits="11" />
            </IntegerParameterType>
            <IntegerParameterType name="CCSDS_Sequence_Count_Type" signed="false">
                <UnitSet />
                <IntegerDataEncoding sizeInBits="14" />
            </IntegerParameterType>
            <AggregateParameterType name="CCSDS_Packet_ID_Type">
                <MemberList>
                    <Member name="Version" typeRef="CCSDS_Version_Type" />
                    <Member name="Type" typeRef="CCSDS_Type_Type" />
                    <Member name="SecHdrFlag" typeRef="CCSDS_Sec_Hdr_Flag_Type" />
                    <Member name="APID" typeRef="CCSDS_APID_Type" />
                </MemberList>
            </AggregateParameterType>

            <!-- Basic Types -->
            <FloatParameterType name="float_t">
                <UnitSet />
                <FloatDataEncoding sizeInBits="64" />  <!-- Changed to double precision -->
            </FloatParameterType>
            <BooleanParameterType name="bool_t">
                <UnitSet />
                <IntegerDataEncoding sizeInBits="8" />
            </BooleanParameterType>

            <!-- Specialized Types -->
            <FloatParameterType name="position_t">
                <UnitSet>
                    <Unit>m</Unit>
                </UnitSet>
                <FloatDataEncoding sizeInBits="64" />
            </FloatParameterType>
            <FloatParameterType name="velocity_t">
                <UnitSet>
                    <Unit>m/s</Unit>
                </UnitSet>
                <FloatDataEncoding sizeInBits="64" />
            </FloatParameterType>
            <FloatParameterType name="angular_velocity_t">
                <UnitSet>
                    <Unit>rad/s</Unit>
                </UnitSet>
                <FloatDataEncoding sizeInBits="64" />
            </FloatParameterType>
            <FloatParameterType name="quaternion_t">
                <UnitSet />
                <FloatDataEncoding sizeInBits="64" />
            </FloatParameterType>
            <FloatParameterType name="power_t">
                <UnitSet>
                    <Unit>W</Unit>
                </UnitSet>
                <FloatDataEncoding sizeInBits="64" />
            </FloatParameterType>
            <FloatParameterType name="temperature_t">
                <UnitSet>
                    <Unit>K</Unit>
                </UnitSet>
                <FloatDataEncoding sizeInBits="64" />
            </FloatParameterType>
            <IntegerParameterType name="counter_t" signed="false">
                <UnitSet />
                <IntegerDataEncoding sizeInBits="32" />
            </IntegerParameterType>
            <IntegerParameterType name="storage_t" signed="false">
                <UnitSet>
                    <Unit>bytes</Unit>
                </UnitSet>
                <IntegerDataEncoding sizeInBits="64" />
            </IntegerParameterType>
			<EnumeratedParameterType name="EventSeverity">
				<UnitSet />
				<IntegerDataEncoding sizeInBits="8" />
				<EnumerationList>
					<Enumeration label="INFO" value="0" />
					<Enumeration label="WARNING" value="1" />
					<Enumeration label="ERROR" value="2" />
					<Enumeration label="CRITICAL" value="3" />
				</EnumerationList>
			</EnumeratedParameterType>
			<StringParameterType name="EventMessage">
				<UnitSet />
				<StringDataEncoding>
					<SizeInBits>2040</SizeInBits>
				</StringDataEncoding>
			</StringParameterType>
        </ParameterTypeSet>

        <ParameterSet>
            <!-- CCSDS Headers -->
            <Parameter name="CCSDS_Packet_ID" parameterTypeRef="CCSDS_Packet_ID_Type" />
            <Parameter name="CCSDS_Sequence_Count" parameterTypeRef="CCSDS_Sequence_Count_Type" />
            <Parameter name="CCSDS_Packet_Length" parameterTypeRef="uint16_t" />
			
			<!-- Event Parameters -->	
			<Parameter name="Event_Severity" parameterTypeRef="EventSeverity" />
			<Parameter name="Event_Message" parameterTypeRef="EventMessage" />
			<Parameter name="Event_Time" parameterTypeRef="uint64_t" />
			<Parameter name="Event_Subsystem" parameterTypeRef="string" />

            <!-- State Vector Parameters -->
            <Parameter name="Position_X" parameterTypeRef="position_t" />
            <Parameter name="Position_Y" parameterTypeRef="position_t" />
            <Parameter name="Position_Z" parameterTypeRef="position_t" />
            <Parameter name="Velocity_X" parameterTypeRef="velocity_t" />
            <Parameter name="Velocity_Y" parameterTypeRef="velocity_t" />
            <Parameter name="Velocity_Z" parameterTypeRef="velocity_t" />
            
            <!-- Attitude Parameters -->
            <Parameter name="Attitude_W" parameterTypeRef="quaternion_t" />
            <Parameter name="Attitude_X" parameterTypeRef="quaternion_t" />
            <Parameter name="Attitude_Y" parameterTypeRef="quaternion_t" />
            <Parameter name="Attitude_Z" parameterTypeRef="quaternion_t" />
            <Parameter name="Angular_Velocity_X" parameterTypeRef="angular_velocity_t" />
            <Parameter name="Angular_Velocity_Y" parameterTypeRef="angular_velocity_t" />
            <Parameter name="Angular_Velocity_Z" parameterTypeRef="angular_velocity_t" />

            <!-- Power Parameters -->
            <Parameter name="Battery_Level" parameterTypeRef="float_t" />
            <Parameter name="Solar_Power" parameterTypeRef="power_t" />
            <Parameter name="Power_Consumption" parameterTypeRef="power_t" />
            
            <!-- Thermal Parameters -->
            <Parameter name="Temperature" parameterTypeRef="temperature_t" />

            <!-- ADCS Parameters -->
            <Parameter name="Wheel_Speed_X" parameterTypeRef="angular_velocity_t" />
            <Parameter name="Wheel_Speed_Y" parameterTypeRef="angular_velocity_t" />
            <Parameter name="Wheel_Speed_Z" parameterTypeRef="angular_velocity_t" />
            <Parameter name="Magnetorquer_X" parameterTypeRef="float_t" />
            <Parameter name="Magnetorquer_Y" parameterTypeRef="float_t" />
            <Parameter name="Magnetorquer_Z" parameterTypeRef="float_t" />
            <Parameter name="Magnetic_Field_X" parameterTypeRef="float_t" />
            <Parameter name="Magnetic_Field_Y" parameterTypeRef="float_t" />
            <Parameter name="Magnetic_Field_Z" parameterTypeRef="float_t" />

            <!-- Payload Parameters -->
            <Parameter name="Imaging_Active" parameterTypeRef="bool_t" />
            <Parameter name="Images_Taken" parameterTypeRef="counter_t" />
            <Parameter name="Storage_Used" parameterTypeRef="storage_t" />
            <Parameter name="Storage_Available" parameterTypeRef="storage_t" />
        </ParameterSet>

        <ContainerSet>
            <!-- Base CCSDS Container -->
            <SequenceContainer abstract="true" name="CCSDSPacket">
                <EntryList>
                    <ParameterRefEntry parameterRef="CCSDS_Packet_ID" />
                    <ParameterRefEntry parameterRef="CCSDS_Sequence_Count" />
                    <ParameterRefEntry parameterRef="CCSDS_Packet_Length" />
                </EntryList>
            </SequenceContainer>

			<!-- Event Container -->	
			<SequenceContainer name="Event">
				<EntryList>
					<ParameterRefEntry parameterRef="Event_Time" />
					<ParameterRefEntry parameterRef="Event_Severity" />
					<ParameterRefEntry parameterRef="Event_Subsystem" />
					<ParameterRefEntry parameterRef="Event_Message" />
				</EntryList>
				<BaseContainer containerRef="CCSDSPacket">
					<RestrictionCriteria>
						<ComparisonList>
							<Comparison parameterRef="CCSDS_Packet_ID/APID" value="57344" /> <!-- 0xE000 -->
						</ComparisonList>
					</RestrictionCriteria>
				</BaseContainer>
			</SequenceContainer>

            <!-- Housekeeping Telemetry -->
            <SequenceContainer name="Housekeeping">
                <EntryList>
                    <ParameterRefEntry parameterRef="Position_X" />
                    <ParameterRefEntry parameterRef="Position_Y" />
                    <ParameterRefEntry parameterRef="Position_Z" />
                    <ParameterRefEntry parameterRef="Velocity_X" />
                    <ParameterRefEntry parameterRef="Velocity_Y" />
                    <ParameterRefEntry parameterRef="Velocity_Z" />
                    <ParameterRefEntry parameterRef="Attitude_W" />
                    <ParameterRefEntry parameterRef="Attitude_X" />
                    <ParameterRefEntry parameterRef="Attitude_Y" />
                    <ParameterRefEntry parameterRef="Attitude_Z" />
                    <ParameterRefEntry parameterRef="Angular_Velocity_X" />
                    <ParameterRefEntry parameterRef="Angular_Velocity_Y" />
                    <ParameterRefEntry parameterRef="Angular_Velocity_Z" />
                    <ParameterRefEntry parameterRef="Battery_Level" />
                    <ParameterRefEntry parameterRef="Temperature" />
                </EntryList>
                <BaseContainer containerRef="CCSDSPacket">
                    <RestrictionCriteria>
                        <ComparisonList>
                            <Comparison parameterRef="CCSDS_Packet_ID/APID" value="256" /> <!-- 0x100 -->
                        </ComparisonList>
                    </RestrictionCriteria>
                </BaseContainer>
            </SequenceContainer>

            <!-- ADCS Telemetry -->
            <SequenceContainer name="ADCS">
                <EntryList>
                    <ParameterRefEntry parameterRef="Wheel_Speed_X" />
                    <ParameterRefEntry parameterRef="Wheel_Speed_Y" />
                    <ParameterRefEntry parameterRef="Wheel_Speed_Z" />
                    <ParameterRefEntry parameterRef="Magnetorquer_X" />
                    <ParameterRefEntry parameterRef="Magnetorquer_Y" />
                    <ParameterRefEntry parameterRef="Magnetorquer_Z" />
                    <ParameterRefEntry parameterRef="Magnetic_Field_X" />
                    <ParameterRefEntry parameterRef="Magnetic_Field_Y" />
                    <ParameterRefEntry parameterRef="Magnetic_Field_Z" />
                </EntryList>
                <BaseContainer containerRef="CCSDSPacket">
                    <RestrictionCriteria>
                        <ComparisonList>
                            <Comparison parameterRef="CCSDS_Packet_ID/APID" value="257" /> <!-- 0x101 -->
                        </ComparisonList>
                    </RestrictionCriteria>
                </BaseContainer>
            </SequenceContainer>

            <!-- Power Telemetry -->
            <SequenceContainer name="Power">
                <EntryList>
                    <ParameterRefEntry parameterRef="Battery_Level" />
                    <ParameterRefEntry parameterRef="Solar_Power" />
                    <ParameterRefEntry parameterRef="Power_Consumption" />
                </EntryList>
                <BaseContainer containerRef="CCSDSPacket">
                    <RestrictionCriteria>
                        <ComparisonList>
                            <Comparison parameterRef="CCSDS_Packet_ID/APID" value="258" /> <!-- 0x102 -->
                        </ComparisonList>
                    </RestrictionCriteria>
                </BaseContainer>
            </SequenceContainer>

            <!-- Payload Telemetry -->
            <SequenceContainer name="Payload">
                <EntryList>
                    <ParameterRefEntry parameterRef="Imaging_Active" />
                    <ParameterRefEntry parameterRef="Images_Taken" />
                    <ParameterRefEntry parameterRef="Storage_Used" />
                    <ParameterRefEntry parameterRef="Storage_Available" />
                </EntryList>
                <BaseContainer containerRef="CCSDSPacket">
                    <RestrictionCriteria>
                        <ComparisonList>
                            <Comparison parameterRef="CCSDS_Packet_ID/APID" value="259" /> <!-- 0x103 -->
                        </ComparisonList>
                    </RestrictionCriteria>
                </BaseContainer>
            </SequenceContainer>
        </ContainerSet>
    </TelemetryMetaData>

    <CommandMetaData>
        <ArgumentTypeSet>
            <FloatArgumentType name="quaternion_arg_t">
                <UnitSet />
                <FloatDataEncoding sizeInBits="64" />
            </FloatArgumentType>
            <EnumeratedArgumentType name="adcs_mode_t">
                <UnitSet />
                <IntegerDataEncoding sizeInBits="8" />
                <EnumerationList>
                    <Enumeration label="NADIR" value="0" />
                    <Enumeration label="SUNPOINTING" value="1" />
                    <Enumeration label="CUSTOM" value="2" />
                </EnumerationList>
            </EnumeratedArgumentType>
            <FloatArgumentType name="wheel_speed_t">
                <UnitSet>
                    <Unit>rad/s</Unit>
                </UnitSet>
                <FloatDataEncoding sizeInBits="64" />
            </FloatArgumentType>
            <FloatArgumentType name="magnetic_dipole_t">
                <UnitSet>
                    <Unit>Am²</Unit>
                </UnitSet>
                <FloatDataEncoding sizeInBits="64" />
            </FloatArgumentType>
        </ArgumentTypeSet>

        <MetaCommandSet>
            <!-- ADCS Commands -->
            <MetaCommand name="adcs_set_target_attitude">
                <ArgumentList>
                    <Argument name="qw" argumentTypeRef="quaternion_arg_t" />
                    <Argument name="qx" argumentTypeRef="quaternion_arg_t" />
                    <Argument name="qy" argumentTypeRef="quaternion_arg_t" />
                    <Argument name="qz" argumentTypeRef="quaternion_arg_t" />
                </ArgumentList>
                <CommandContainer name="adcs_set_target_attitude">
                    <FixedValue name="Subsystem" binaryValue="0x01" sizeInBits="8" />
                    <FixedValue name="Command" binaryValue="0x01" sizeInBits="8" />
                </CommandContainer>
            </MetaCommand>

            <MetaCommand name="adcs_set_mode">
                <ArgumentList>
                    <Argument name="mode" argumentTypeRef="adcs_mode_t" />
                </ArgumentList>
                <CommandContainer name="adcs_set_mode">
                    <FixedValue name="Subsystem" binaryValue="0x01" sizeInBits="8" />
                    <FixedValue name="Command" binaryValue="0x02" sizeInBits="8" />
                </CommandContainer>
            </MetaCommand>

            <MetaCommand name="adcs_reset_wheels">
                <CommandContainer name="adcs_reset_wheels">
                    <FixedValue name="Subsystem" binaryValue="0x01" sizeInBits="8" />
                    <FixedValue name="Command" binaryValue="0x03" sizeInBits="8" />
                </CommandContainer>
            </MetaCommand>

            <!-- Payload Commands -->
            <MetaCommand name="payload_start_imaging">
                <ArgumentList>
                    <Argument name="state" argumentTypeRef="bool_t" />
                </ArgumentList>
                <CommandContainer name="payload_start_imaging">
                    <FixedValue name="Subsystem" binaryValue="0x04" sizeInBits="8" />
                    <FixedValue name="Command" binaryValue="0x01" sizeInBits="8" />
                </CommandContainer>
            </MetaCommand>

            <MetaCommand name="payload_take_image">
                <CommandContainer name="payload_take_image">
                    <FixedValue name="Subsystem" binaryValue="0x04" sizeInBits="8" />
                    <FixedValue name="Command" binaryValue="0x03" sizeInBits="8" />
                </CommandContainer>
            </MetaCommand>
        </MetaCommandSet>
    </CommandMetaData>
</SpaceSystem>